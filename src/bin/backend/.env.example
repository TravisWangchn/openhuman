# OpenHuman-ZN 国产化 Backend 环境变量
#
# 部署到阿里云 ECS 时复制此文件为 .env 并填入实际值

# JWT 签名密钥（必填，至少 32 字符）
OPENHUMAN_JWT_SECRET=your-secret-key-at-least-32-chars

# 飞书应用凭证（从飞书开放平台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 微信支付商户配置
WECHAT_MCH_ID=1234567890
WECHAT_API_V3_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 支付宝应用配置
ALIPAY_APP_ID=2021000000000000
ALIPAY_PRIVATE_KEY_PATH=/etc/openhuman/alipay_private_key.pem

# 数据库路径
OPENHUMAN_DB_PATH=./data/backend.db

# 监听地址
OPENHUMAN_BIND=0.0.0.0:3000
